# Copy to .env (or set these in the environment / docker compose) ------------

APP_NAME="CA Pharmacy API"
APP_ENV=local
APP_DEBUG=true

# Sales tax applied at point of sale, as a fraction (0.08 = 8%).
TAX_RATE=0

# Database (matches the compose.yaml defaults) -------------------------------
DB_HOST=db
DB_PORT=5432
DB_DATABASE=ca_pharmacy
DB_USERNAME=ca_pharmacy
DB_PASSWORD=ca_pharmacy
